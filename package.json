{
	"name": "rawstyle-vscode",
	"version": "0.0.0",
	"author": "kh4f <kh4f.dev@gmail.com>",
	"license": "MIT",
	"repository": "https://github.com/rawstylecss/rawstyle-vscode",
	"bugs": "https://github.com/rawstylecss/rawstyle-vscode/issues",
	"homepage": "https://github.com/rawstylecss/rawstyle-vscode#readme",
	"keywords": ["rawstyle", "rawstyle-vscode", "css-in-js"],
	"pnpm": { "onlyBuiltDependencies": ["esbuild"] },
	"engines": { "vscode": ">=1.109.x" },
	"type": "module",
	"main": "dist/index.js",
	"activationEvents": ["onLanguage:typescriptreact"],
	"contributes": {
		"grammars": [
			{
				"scopeName": "rawstyle.css.injection",
				"path": "syntaxes/injection.json",
				"injectTo": ["source.tsx"],
				"embeddedLanguages": {"meta.embedded.block.css": "css"}
			}
		]
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"build:prod": "tsdown --prod",
		"lint": "eslint",
		"release": "relion"
	},
	"devDependencies": {
		"@eslint-react/eslint-plugin": "^2.7.4",
		"@eslint/css": "^0.14.1",
		"@eslint/js": "^9.39.2",
		"@stylistic/eslint-plugin": "^5.7.1",
		"@types/eslint-plugin-jsx-a11y": "^6.10.1",
		"@types/node": "^25.0.10",
		"@types/react": "^19.2.9",
		"@types/react-dom": "^19.2.3",
		"@types/vscode": "^1.108.1",
		"eslint": "^9.39.2",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"jiti": "^2.6.1",
		"rawstyle": "^0.2.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"relion": "^0.37.0",
		"tsdown": "^0.20.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vscode-css-languageservice": "^6.3.9",
		"vscode-languageserver-textdocument": "^1.0.12"
	}
}